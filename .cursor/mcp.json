{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "agentation": {
            "command": "npx",
            "args": [
                "agentation-mcp",
                "server"
            ]
        }
    }
}